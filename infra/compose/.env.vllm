# CloudApp vLLM Mode Configuration
# Uses local vLLM instance for LLM, mock for ASR/TTS

# Provider Selection
CLOUDAPP_ASR_PROVIDER=mock
CLOUDAPP_LLM_PROVIDER=openai_compatible
CLOUDAPP_TTS_PROVIDER=mock

# vLLM Configuration (running on host via host.docker.internal)
CLOUDAPP_LLM_BASE_URL=http://host.docker.internal:8000/v1
CLOUDAPP_LLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
CLOUDAPP_LLM_API_KEY=dummy-key-for-vllm

# Infrastructure
CLOUDAPP_REDIS_ADDR=redis:6379
CLOUDAPP_POSTGRES_DSN=postgres://voiceengine:voiceengine@postgres:5432/voiceengine?sslmode=disable

# Provider Gateway Connection
CLOUDAPP_PROVIDER_GATEWAY_ADDR=provider-gateway:50051

# Logging
CLOUDAPP_LOG_LEVEL=debug
CLOUDAPP_LOG_FORMAT=json

# Observability
CLOUDAPP_OBSERVABILITY_ENABLE_METRICS=true
CLOUDAPP_OBSERVABILITY_ENABLE_TRACING=false

# Security (relaxed for local dev)
CLOUDAPP_SECURITY_AUTH_ENABLED=false
