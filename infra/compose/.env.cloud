# CloudApp Cloud Providers Mode Configuration
# Uses Google Speech for ASR/TTS and Groq for LLM

# Provider Selection
CLOUDAPP_ASR_PROVIDER=google_speech
CLOUDAPP_LLM_PROVIDER=groq
CLOUDAPP_TTS_PROVIDER=google_tts

# Cloud Provider Credentials
# Set GROQ_API_KEY in your environment before running: export GROQ_API_KEY=your_key_here
CLOUDAPP_GROQ_API_KEY=${GROQ_API_KEY}
CLOUDAPP_GROQ_MODEL=llama3-70b-8192

# Google Cloud credentials - mount your service account key
# docker-compose -f infra/compose/docker-compose.yml -f infra/compose/docker-compose.cloud.yml up
CLOUDAPP_GOOGLE_CREDENTIALS_PATH=/secrets/google-credentials.json
CLOUDAPP_GOOGLE_PROJECT_ID=${GOOGLE_PROJECT_ID}

# Infrastructure
CLOUDAPP_REDIS_ADDR=redis:6379
CLOUDAPP_POSTGRES_DSN=postgres://voiceengine:voiceengine@postgres:5432/voiceengine?sslmode=disable

# Provider Gateway Connection
CLOUDAPP_PROVIDER_GATEWAY_ADDR=provider-gateway:50051

# Logging
CLOUDAPP_LOG_LEVEL=info
CLOUDAPP_LOG_FORMAT=json

# Observability
CLOUDAPP_OBSERVABILITY_ENABLE_METRICS=true
CLOUDAPP_OBSERVABILITY_ENABLE_TRACING=true
CLOUDAPP_OBSERVABILITY_OTEL_ENDPOINT=localhost:4317

# Security
CLOUDAPP_SECURITY_AUTH_ENABLED=true
CLOUDAPP_SECURITY_AUTH_TOKEN=${CLOUDAPP_AUTH_TOKEN}
