# CloudApp Mock Mode Configuration
# All providers use mock implementations for local testing

# Provider Selection
CLOUDAPP_PROVIDERS_DEFAULT_ASR=mock
CLOUDAPP_PROVIDERS_DEFAULT_LLM=mock  
CLOUDAPP_PROVIDERS_DEFAULT_TTS=mock
CLOUDAPP_PROVIDERS_DEFAULT_VAD=mock

# Infrastructure (these are set in docker-compose.yml directly)
# CLOUDAPP_REDIS_ADDRESS=redis:6379
# CLOUDAPP_POSTGRES_DSN=postgres://voiceengine:voiceengine@postgres:5432/voiceengine?sslmode=disable

# Logging
CLOUDAPP_OBSERVABILITY_LOG_LEVEL=debug
CLOUDAPP_OBSERVABILITY_LOG_FORMAT=json

# Observability
CLOUDAPP_OBSERVABILITY_ENABLE_METRICS=true
CLOUDAPP_OBSERVABILITY_ENABLE_TRACING=false

# Security (relaxed for local dev)
CLOUDAPP_SECURITY_AUTH_ENABLED=false
